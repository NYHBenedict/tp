@startuml
skin rose
skinparam ActivityFontSize 15
skinparam ArrowFontSize 12

'Since the beta syntax does not support placing the condition outside the
'diamond we place it as the true branch instead.

start
:Parse command arguments;

if () then ([missing required prefix or invalid format?])
    :Return format error message;
    stop
else ([else])
endif

if () then ([invalid course code?])
    :Return invalid course code message;
    stop
else ([else])
endif

if () then ([duplicate course code in same command?])
    :Return duplicate course code input message;
    stop
else ([else])
endif

if () then ([course already exists?])
    :Return course already exists message;
    stop
else ([else])
endif

:Add course to model;
:Reset course-related display state;
:Save changes in storage;

if () then ([save failed?])
    :return unable to save changes message;
    stop
else ([else])
endif

:Show success message;
stop
@enduml
